# EditorConfig — consistent indentation / line endings / charset across editors.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Web / config files follow the 2-space community norm; PHP keeps the 4-space
# default above (PSR-12).
[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,scss,less,html,vue,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# Extensionless JSON/YAML dotfiles also follow the 2-space norm.
[.prettierrc]
indent_size = 2

# NEON (PHPStan) is tab-indented — match the tool's own --generate-baseline output.
[*.neon]
indent_style = tab
