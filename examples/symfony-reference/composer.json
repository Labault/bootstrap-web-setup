{
  "name": "ref/app",
  "description": "Reference project used by CI to prove the deposited symfony pipeline runs green.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.64",
    "rector/rector": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
